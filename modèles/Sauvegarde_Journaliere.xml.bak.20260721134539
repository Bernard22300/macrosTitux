<?xml version="1.0" encoding="UTF-8"?>
<macro name="Sauvegarde_Journaliere">
    <trigger type="HORAIRE" label="Horaire (cron)">
        <config>
            <param key="heure" value="8"/>
            <param key="minute" value="0"/>
            <param key="jours" value="* * * * *"/>
        </config>
    </trigger>
    <variables>
        <var name="SOURCE" value="$HOME/Documents"/>
        <var name="DEST" value="$HOME/backup/Documents"/>
    </variables>
    <actions>
        <action id="1" type="COPIER_FICHIER" label="Copier fichier(s)">
            <config>
                <param key="source" value="/home/bernard/Documents"/>
                <param key="destination" value="/home/bernard/backup/Documents"/>
                <param key="motif" value="*"/>
            </config>
        </action>
        <action id="2" type="NOTIFIER" label="Notifier">
            <config>
                <param key="titre" value="Sauvegarde termine"/>
                <param key="message" value="Documents sauvegardes avec succes"/>
            </config>
        </action>
    </actions>
    <constraints>
        <constraint id="1" type="ESPACE_DISQUE" label="Espace disque">
            <config>
                <param key="espace_minimum" value="10"/>
            </config>
        </constraint>
    </constraints>
</macro>
