<?xml version="1.0" encoding="UTF-8"?>
<macro name="Sauvegarde_Journaliere">
    <declencheur type="HORAIRE" label="Horaire (cron)">
        <config>
            <parametre key="heure" value="8"/>
            <parametre key="minute" value="0"/>
            <parametre key="jours" value="* * * * *"/>
        </config>
    </declencheur>
    <variables>
        <variable name="SOURCE" value="$HOME/Documents"/>
        <variable name="DEST" value="$HOME/backup/Documents"/>
    </variables>
    <actions>
        <action id="1" type="COPIER_FICHIER" label="Copier fichier(s)">
            <config>
                <parametre key="source" value="/home/bernard/Documents"/>
                <parametre key="destination" value="/home/bernard/backup/Documents"/>
                <parametre key="motif" value="*"/>
            </config>
        </action>
        <action id="2" type="NOTIFIER" label="Notifier">
            <config>
                <parametre key="titre" value="Sauvegarde termine"/>
                <parametre key="message" value="Documents sauvegardes avec succes"/>
            </config>
        </action>
    </actions>
    <contraintes>
        <contrainte id="1" type="ESPACE_DISQUE" label="Espace disque">
            <config>
                <parametre key="espace_minimum" value="10"/>
            </config>
        </contrainte>
    </contraintes>
</macro>
