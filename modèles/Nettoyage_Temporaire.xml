<?xml version="1.0" encoding="UTF-8"?>
<macro name="Nettoyage_Temporaire">
    <declencheur type="HORAIRE" label="Horaire (cron)">
        <config>
            <parametre key="heure" value="22"/>
            <parametre key="minute" value="0"/>
            <parametre key="jours" value="* * * * *"/>
        </config>
    </declencheur>
    <variables>
        <variable name="TMP_DIR" value="/tmp"/>
    </variables>
    <actions>
        <action id="1" type="NOTIFIER" label="Notifier">
            <config>
                <parametre key="titre" value="Nettoyage"/>
                <parametre key="message" value="Departement des fichiers temporaires"/>
            </config>
        </action>
        <action id="2" type="EXECUTER_CMD" label="Exécuter commande">
            <config>
                <parametre key="commande" value="find /tmp -type f -mtime +7 -delete"/>
            </config>
        </action>
        <action id="3" type="NOTIFIER" label="Notifier">
            <config>
                <parametre key="titre" value="Nettoyage termine"/>
                <parametre key="message" value="Fichiers de plus de 7 jours supprimes"/>
            </config>
        </action>
    </actions>
    <contraintes>
        <contrainte id="1" type="PLAGE_HORAIRE" label="Plage horaire">
            <config>
                <parametre key="heure_debut" value="2200"/>
                <parametre key="heure_fin" value="2359"/>
            </config>
        </contrainte>
    </contraintes>
</macro>
