<?xml version="1.0" encoding="UTF-8"?>
<macro name="Archi_Mensuelle">
    <declencheur type="HORAIRE" label="Horaire (cron)">
        <config>
            <parametre key="heure" value="18"/>
            <parametre key="minute" value="0"/>
            <parametre key="jours" value="01 * * *"/>
        </config>
    </declencheur>
    <variables>
        <variable name="MOIS" value="$(date +%Y%m)"/>
        <variable name="ARCHIVE_NAME" value="PDF_Archive_${MOIS}.tar.gz"/>
    </variables>
    <actions>
        <action id="1" type="COPIER_FICHIER" label="Copier fichier(s)">
            <config>
                <parametre key="source" value="$HOME/Documents/*.pdf"/>
                <parametre key="destination" value="/tmp/archi_temp/"/>
                <parametre key="motif" value="*.pdf"/>
            </config>
        </action>
        <action id="2" type="EXECUTER_CMD" label="Exécuter commande">
            <config>
                <parametre key="commande" value="tar -czf $HOME/Archives/${ARCHIVE_NAME} -C /tmp/archi_temp ."/>
            </config>
        </action>
        <action id="3" type="NOTIFIER" label="Notifier">
            <config>
                <parametre key="titre" value="Archive mensuelle"/>
                <parametre key="message" value="PDF archives pour ${MOIS}"/>
            </config>
        </action>
    </actions>
    <contraintes>
        <contrainte id="1" type="ESPACE_DISQUE" label="Espace disque">
            <config>
                <parametre key="espace_minimum" value="20"/>
            </config>
        </contrainte>
    </contraintes>
</macro>
