<?xml version="1.0" encoding="UTF-8"?>
<macro name="Surveillance_CPU">
    <declencheur type="HORAIRE" label="Horaire (cron)">
        <config>
            <parametre key="heure" value="*"/>
            <parametre key="minute" value="*/30"/>
            <parametre key="jours" value="* * * * *"/>
        </config>
    </declencheur>
    <variables>
        <variable name="THRESHOLD" value="90"/>
    </variables>
    <actions>
        <action id="1" type="EXECUTER_CMD" label="Exécuter commande">
            <config>
                <parametre key="commande" value="cpu_usage=$(top -bn1 | grep 'Cpu(s)' | awk '{print $2}' | cut -d'%' -f1); echo CPU: $cpu_usage"/>
            </config>
        </action>
        <action id="2" type="NOTIFIER" label="Notifier">
            <config>
                <parametre key="titre" value="Alerte CPU"/>
                <parametre key="message" value="CPU eleve: verifier les programmes en cours"/>
            </config>
        </action>
    </actions>
    <contraintes>
        <contrainte id="1" type="PROCESSUS_ACTIF" label="Processus actif">
            <config>
                <parametre key="processus" value="gnome-system-monitor"/>
            </config>
        </contrainte>
    </contraintes>
</macro>
